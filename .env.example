# ---------------------------------------------------------------------------
# Configuration template. Copy this file to `.env` and edit as needed.
# NEVER commit the real .env (it is gitignored).
#
# The DEFAULT data provider is yfinance, which needs NO API KEY — so you can run
# the project immediately without setting anything here.
# ---------------------------------------------------------------------------

# Which market-data backend to use: yfinance | fmp | alpaca
APP_DATA_PROVIDER=yfinance

# ---------------------------------------------------------------------------
# Financial Modeling Prep (only needed if APP_DATA_PROVIDER=fmp)
# Get a free key: https://site.financialmodelingprep.com/developer/docs
# ---------------------------------------------------------------------------
# FMP_API_KEY=your_fmp_key_here
# FMP_BASE_URL=https://financialmodelingprep.com/api/v3

# ---------------------------------------------------------------------------
# Alpaca Market Data v2 (only needed if APP_DATA_PROVIDER=alpaca)
# Get keys: https://app.alpaca.markets/  (paper-trading keys work for data)
# ---------------------------------------------------------------------------
# ALPACA_API_KEY=your_api_key_here
# ALPACA_SECRET_KEY=your_secret_key_here
# ALPACA_BASE_URL=https://data.alpaca.markets

# ---------------------------------------------------------------------------
# Optional overrides (defaults live in config/settings.py), APP_ prefix:
# ---------------------------------------------------------------------------
# APP_TICKER=CEG
# APP_START_DATE=2022-01-01
# APP_TIMEFRAME=1Day
# APP_TIMEZONE=America/New_York
# APP_FORECAST_HORIZON=5
# APP_BACKTEST_WINDOW=252
# APP_LOG_LEVEL=INFO
